  <script>
    const pages = Array.from(document.querySelectorAll('.app .page'));

    // --- SỬA LOGIC: LẤY TRẠNG THÁI TỪ LOCALSTORAGE ĐỂ TRÁNH MẤT KHI RESET/F5 ---
    let currentIdx = parseInt(localStorage.getItem('wp_currentIdx')) || 0;
    let selectedBranch = localStorage.getItem('wp_selectedBranch') || null;

    // Biến phục vụ đếm ngược thời gian
    let countdownInterval = null;
    let remainingTime = 0;

    function selectBranch(branchName) {
      selectedBranch = branchName;
      localStorage.setItem('wp_selectedBranch', branchName); // Lưu lại đề đã chọn

      document.getElementById('opt-de1').classList.toggle('selected', branchName === 'de1');
      document.getElementById('opt-de2').classList.toggle('selected', branchName === 'de2');

      handleMove(1);
    }

    function renderActivePage() {
      pages.forEach((page, idx) => {
        page.classList.toggle('active', idx === currentIdx);
      });

      document.getElementById('btn-prev').disabled = (currentIdx === 0);

      const isLastPage = (currentIdx === pages.length - 1);
      const btnNext = document.getElementById('btn-next');
      btnNext.textContent = isLastPage ? 'Hoàn thành' : 'Tiếp tục →';
      btnNext.disabled = false;

      if (pages[currentIdx].id === 'pg-7' && !selectedBranch) {
        btnNext.disabled = true;
      } else {
        btnNext.disabled = false;
      }

      // Đồng bộ trạng thái class selected cho các nút chọn đề khi tải lại trang
      if (document.getElementById('opt-de1') && document.getElementById('opt-de2')) {
        document.getElementById('opt-de1').classList.toggle('selected', selectedBranch === 'de1');
        document.getElementById('opt-de2').classList.toggle('selected', selectedBranch === 'de2');
      }

      // --- SỬA LOGIC: ĐẾM NGƯỢC 3 PHÚT Ở BƯỚC 8 (CẢ 2 ĐỀ) ---
      clearInterval(countdownInterval);
      const currentPage = pages[currentIdx];

      if (currentPage.getAttribute('data-countdown') === 'true') {
        // Kiểm tra xem bước này đã đếm xong trước đó chưa
        const isTimerDone = localStorage.getItem(`wp_timer_done_${currentPage.id}`);

        if (!isTimerDone) {
          // Kiểm tra xem có thời gian đang chạy dở được lưu trong localStorage không
          const savedTime = localStorage.getItem(`wp_remaining_time_${currentPage.id}`);
          if (savedTime !== null) {
            remainingTime = parseInt(savedTime);
          } else {
            remainingTime = 180; // 3 phút = 180 giây
          }

          if (remainingTime > 0) {
            btnNext.disabled = true;
            updateTimerText(btnNext, remainingTime);

            countdownInterval = setInterval(() => {
              remainingTime--;
              localStorage.setItem(`wp_remaining_time_${currentPage.id}`, remainingTime);

              if (remainingTime <= 0) {
                clearInterval(countdownInterval);
                btnNext.disabled = false;
                btnNext.textContent = isLastPage ? 'Hoàn thành' : 'Tiếp tục →';
                localStorage.setItem(`wp_timer_done_${currentPage.id}`, 'true');
                localStorage.removeItem(`wp_remaining_time_${currentPage.id}`);
              } else {
                updateTimerText(btnNext, remainingTime);
              }
            }, 1000);
          }
        }
      }
    }

    function updateTimerText(buttonEl, timeInSeconds) {
      const minutes = Math.floor(timeInSeconds / 60);
      const seconds = timeInSeconds % 60;
      const formattedSeconds = seconds < 10 ? '0' + seconds : seconds;
      buttonEl.textContent = `Tiếp tục (${minutes}:${formattedSeconds})`;
    }

    function handleMove(direction) {
      let nextIdx = currentIdx + direction;

      while (nextIdx >= 0 && nextIdx < pages.length) {
        const nextPage = pages[nextIdx];
        const pageBranch = nextPage.getAttribute('data-branch');

        if (!pageBranch || pageBranch === selectedBranch) {
          currentIdx = nextIdx;
          localStorage.setItem('wp_currentIdx', currentIdx); // Lưu lại vị trí trang hiện tại
          window.scrollTo(0, 0);
          renderActivePage();
          return;
        }

        nextIdx += direction;
      }
    }

    function tick(el) {
      el.classList.toggle('done');
      const container = pages[currentIdx];
      const all = container.querySelectorAll('.cl-item');
      const done = container.querySelectorAll('.cl-item.done');
      const doneMsgEl = document.getElementById('done-msg');
      if (doneMsgEl) {
        doneMsgEl.style.display = (done.length === all.length && all.length > 0) ? 'block' : 'none';
      }
    }

    // Khởi chạy hiển thị cấu hình trang chuẩn ban đầu sau khi lấy dữ liệu từ localStorage
    renderActivePage();
  </script>
